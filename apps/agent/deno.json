{
  "name": "@hmls/agent",
  "version": "0.1.0",
  "exports": {
    ".": "./src/mod.ts",
    "./db": "./src/db/client.ts",
    "./order-state": "./src/services/order-state.ts",
    "./order-state-core": "./src/services/order-state-core.ts",
    "./order-intake": "./src/services/order-intake.ts",
    "./auto-assign": "./src/services/auto-assign.ts",
    "./fixo-brain": "./src/fixo/fixo-brain.ts",
    "./common/shop-routing": "./src/common/shop-routing.ts"
  },
  "imports": {
    "@react-pdf/renderer": "npm:@react-pdf/renderer@^4.3.2",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.99.1",
    "react": "npm:react@^19.2.4",
    "nanoid": "npm:nanoid@^5.1.7",
    "drizzle-kit": "npm:drizzle-kit@^0.31.9"
  },
  "lint": {
    "rules": {
      "exclude": ["no-slow-types"]
    }
  },
  "tasks": {
    "db:generate": "deno run -A --node-modules-dir=auto npm:drizzle-kit generate",
    "db:migrate": "deno run -A --node-modules-dir=auto npm:drizzle-kit migrate",
    "db:push": "deno run -A --node-modules-dir=auto npm:drizzle-kit push",
    "db:studio": "deno run -A --node-modules-dir=auto npm:drizzle-kit studio",
    "db:scrape-olp": "deno run --env=../../.env.local --allow-net --allow-env --allow-read src/scripts/scrape-olp.ts",
    "db:seed-providers": "deno run --env=../../.env.local --allow-net --allow-env --allow-read src/scripts/seed-providers.ts",
    "kill-criteria:check": "deno run --env=../../.env.local --allow-net --allow-env --allow-read src/scripts/check-kill-criteria.ts",
    "test": "deno test --allow-env --allow-read --allow-net --allow-sys --allow-ffi src/"
  }
}
