{
  "workspace": ["./apps/gateway", "./apps/agent", "./packages/shared"],
  "nodeModulesDir": "auto",
  "imports": {
    "ai": "npm:ai@^6.0.169",
    "@ai-sdk/google": "npm:@ai-sdk/google@^3.0.65",
    "@ai-sdk/deepseek": "npm:@ai-sdk/deepseek@^2.0.42",
    "hono": "npm:hono@^4.12.14",
    "@hono/zod-validator": "npm:@hono/zod-validator@^0.4.3",
    "zod": "npm:zod@^4.3.6",
    "stripe": "npm:stripe@^20.4.1",
    "drizzle-orm": "npm:drizzle-orm@^0.45.2",
    "drizzle-orm/postgres-js": "npm:drizzle-orm@^0.45.2/postgres-js",
    "drizzle-orm/pg-core": "npm:drizzle-orm@^0.45.2/pg-core",
    "postgres": "npm:postgres@^3.4.9",
    "@db/sqlite": "jsr:@db/sqlite@^0.13.0",
    "@logtape/logtape": "jsr:@logtape/logtape@^2.0.5",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0"
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false,
    "exclude": [
      "apps/hmls-web/",
      "apps/fixo-web/",
      "apps/agent/src/common/data/zip-centroids.json"
    ]
  },
  "lint": {
    "exclude": ["apps/hmls-web/", "apps/fixo-web/"]
  },
  "tasks": {
    "dev:api": "deno task --cwd apps/gateway dev",
    "check:gateway": "deno check apps/gateway/src/index.ts",
    "check:agent": "deno check apps/agent/src/mod.ts",
    "check": "deno task check:gateway && deno task check:agent",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "deno task --cwd apps/gateway test && deno task --cwd apps/agent test",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "deploy": {
    "org": "spinsirr",
    "app": "hmls-api"
  }
}
